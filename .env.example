# X-trafik API Configuration
XTRAFIK_BASE_URL=https://api.xtrafik.example.com

# Client Certificate Authentication (optional; from repo root, certs in ../certs/)
# XTRAFIK_CLIENT_CERT=../certs/server.crt
# XTRAFIK_CLIENT_KEY=../certs/server.key
# XTRAFIK_CA_CERT=../certs/ca-bundle.crt
# XTRAFIK_CLIENT_KEY_PASSPHRASE=   # if the key file is encrypted

# Server Configuration
PORT=3000

# API Authentication (optional)
# API_KEY=your-optional-api-key

# Logging
# LOG_LEVEL=info

# Environment
# NODE_ENV=development
